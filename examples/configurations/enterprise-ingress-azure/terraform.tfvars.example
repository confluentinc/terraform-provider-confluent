# Copy this file to terraform.tfvars and fill in actual values.

confluent_cloud_api_key    = "<confluent-cloud-api-key>"
confluent_cloud_api_secret = "<confluent-cloud-api-secret>"

# Azure region for the gateway and cluster
region = "centralus"

# Prefix for resource names
resource_prefix = "test"

# Environment name
environment_name = "azure-ingress-test"

# Azure Private Endpoint resource ID
# Create this in the Azure portal or via az CLI/Terraform first,
# pointing to the private_link_service_alias from the gateway output.
private_endpoint_resource_id = "/subscriptions/00000000-0000-0000-0000-000000000000/resourceGroups/my-rg/providers/Microsoft.Network/privateEndpoints/my-pe"
