# Copy this file to terraform.tfvars and fill in actual values.

confluent_cloud_api_key    = "<confluent-cloud-api-key>"
confluent_cloud_api_secret = "<confluent-cloud-api-secret>"

# GCP region for the gateway and cluster
region = "us-central1"

# Prefix for resource names
resource_prefix = "test"

# Environment name
environment_name = "gcp-ingress-test"

# GCP Private Service Connect connection ID
# Create this in GCP first (via Console or gcloud), connecting to
# the service_attachment from the gateway output.
private_service_connect_connection_id = "12345678"
